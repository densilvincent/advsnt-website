<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coming Soon | Advanced Systems & Technologies LLC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col justify-center items-center px-6 overflow-hidden">
    <!-- Background Decoration -->
    <div class="absolute inset-0 z-0 opacity-20">
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-blue-600 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-blue-500 rounded-full blur-[120px]"></div>
    </div>

    <main class="relative z-10 max-w-3xl w-full">
        <!-- Company Name (HIGHLIGHTED) -->
        <div class="text-center mb-12">
            <h1 class="text-6xl md:text-7xl font-black tracking-tight mb-3 text-white drop-shadow-2xl">
                Advanced Systems
            </h1>
            <p class="text-3xl md:text-4xl font-light text-blue-400 mb-6">& Technologies LLC</p>

            <!-- Tagline -->
            <p class="text-lg text-slate-300 mb-10 tracking-wide">
                Industrial Equipment Supply & Technical Services
            </p>

            <!-- Coming Soon Badge -->
            <div class="inline-flex items-center gap-3 mb-12 px-6 py-3 rounded-full border border-blue-400/60 bg-gradient-to-r from-blue-500/40 to-blue-400/30 backdrop-blur-sm shadow-lg shadow-blue-500/50">
                <span class="w-3 h-3 bg-blue-300 rounded-full animate-pulse"></span>
                <p class="text-base md:text-lg text-blue-200 font-bold uppercase tracking-widest">Coming Soon</p>
            </div>

            <!-- Contact Section -->
            <div class="space-y-4 mb-16">
                <a href="tel:+971564165464" class="inline-flex items-center gap-3 text-lg hover:text-blue-400 transition-colors">
                    <i class="fas fa-phone text-blue-400 text-xl"></i>
                    <span>+971 56 416 5464</span>
                </a>
                <br/>
                <a href="mailto:Sales@advsnt.com" class="inline-flex items-center gap-3 text-lg hover:text-blue-400 transition-colors">
                    <i class="fas fa-envelope text-blue-400 text-xl"></i>
                    <span>Sales@advsnt.com</span>
                </a>
            </div>
        </div>

        <!-- Service Pillars -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="p-6 bg-slate-800/40 border border-slate-700 rounded-xl hover:border-blue-500/50 hover:bg-slate-800/60 transition-all duration-300 text-center">
                <i class="fas fa-box text-blue-400 text-3xl mb-3 block"></i>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-300">Equipment Supply</p>
            </div>
            <div class="p-6 bg-slate-800/40 border border-slate-700 rounded-xl hover:border-blue-500/50 hover:bg-slate-800/60 transition-all duration-300 text-center">
                <i class="fas fa-screwdriver-wrench text-blue-400 text-3xl mb-3 block"></i>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-300">Repair & Maintenance</p>
            </div>
            <div class="p-6 bg-slate-800/40 border border-slate-700 rounded-xl hover:border-blue-500/50 hover:bg-slate-800/60 transition-all duration-300 text-center">
                <i class="fas fa-microscope text-blue-400 text-3xl mb-3 block"></i>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-300">Inspection & Testing</p>
            </div>
            <div class="p-6 bg-slate-800/40 border border-slate-700 rounded-xl hover:border-blue-500/50 hover:bg-slate-800/60 transition-all duration-300 text-center">
                <i class="fas fa-graduation-cap text-blue-400 text-3xl mb-3 block"></i>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-300">Training & Support</p>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="absolute bottom-8 text-slate-600 text-xs uppercase tracking-widest text-center px-6">
        Advanced Systems & Technologies LLC • UAE
    </footer>
</body>
</html>
